{
  "version": 2,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/netco run build",
  "outputDirectory": "artifacts/netco/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/handler" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "functions": {
    "api/handler.ts": {
      "maxDuration": 30,
      "memory": 256
    }
  },
  "env": {
    "NODE_ENV": "production"
  }
}
